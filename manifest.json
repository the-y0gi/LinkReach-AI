{
  "manifest_version": 3,
  "name": "LinkReach AI",
  "version": "1.0",
  "description": "Generate personalized LinkedIn messages with one click. Just open profile and click the extension. No automation - fully manual copy-paste.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://*.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkReach AI"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
